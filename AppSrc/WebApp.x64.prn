37896>>>                // If from main, this is a propbably a main file Select to Zoom.
37896>>>                Case Break
37897>>>
37897>>>            Case (NavigateData.eNavigateType = nfFromParent)
37900>>>                // If from parent, this is a constrained drill down.
37900>>>                Case Break
37901>>>
37901>>>            Case (NavigateData.eNavigateType = nfFromChild)
37904>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37904>>>                Case Break
37905>>>
37905>>>            Case Else // must be nfUndefined
37905>>>
37905>>>        Case End
37905>>>
37905>>>        Send SetActionButtons
37906>>>
37906>>>    End_Procedure
37907>>>
37907>>>End_Object 
