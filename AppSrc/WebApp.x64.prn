37863>>>    Procedure SetActionButtons
37866>>>        tWebNavigateData NavigateData
37866>>>        tWebNavigateData NavigateData
37866>>>        Boolean bHasRecord
37866>>>        Handle hoDD
37866>>>
37866>>>        Get Server to hoDD
37867>>>        Get GetNavigateData to NavigateData
37868>>>        Get HasRecord of hoDD to bHasRecord
37869>>>
37869>>>        // let's hide all buttons and then Show the ones we want
37869>>>        WebSet pbRender of oEditBtn to False
37870>>>        WebSet pbRender of oSaveBtn to False
37871>>>        WebSet pbRender of oCancelChangesBtn to False
37872>>>        WebSet pbRender of oDeleteBtn to False
37873>>>
37873>>>        If (NavigateData.bReadOnly) Begin
37875>>>            WebSet pbRender of oEditBtn to True
37876>>>        End
37876>>>>
37876>>>        Else Begin
37877>>>            WebSet pbRender of oSaveBtn to True
37878>>>            WebSet pbRender of oCancelChangesBtn to True
37879>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37880>>>        End
37880>>>>
37880>>>    End_Procedure
