38493>>>    Procedure SetActionButtons
38496>>>        tWebNavigateData NavigateData
38496>>>        tWebNavigateData NavigateData
38496>>>        Boolean bHasRecord
38496>>>        Handle hoDD
38496>>>
38496>>>        Get Server to hoDD
38497>>>        Get GetNavigateData to NavigateData
38498>>>        Get HasRecord of hoDD to bHasRecord
38499>>>
38499>>>        // let's hide all buttons and then Show the ones we want
38499>>>        WebSet pbRender of oEditBtn to False
38500>>>        WebSet pbRender of oSaveBtn to False
38501>>>        WebSet pbRender of oCancelChangesBtn to False
38502>>>        WebSet pbRender of oDeleteBtn to False
38503>>>
38503>>>        If (NavigateData.bReadOnly) Begin
38505>>>            WebSet pbRender of oEditBtn to True
38506>>>        End
38506>>>>
38506>>>        Else Begin
38507>>>            WebSet pbRender of oSaveBtn to True
38508>>>            WebSet pbRender of oCancelChangesBtn to True
38509>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38510>>>        End
38510>>>>
38510>>>    End_Procedure
38511>>>
