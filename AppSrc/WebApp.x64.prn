37306>>>    Procedure DoLogin
37309>>>        String sLoginName sPassword sPrevStateHash
37309>>>        Boolean bResult
37309>>>        
37309>>>        WebGet psValue of oLoginName to sLoginName
37310>>>        WebGet psValue of oPassword to sPassword
37311>>>        
37311>>>        Get UserLogin of ghoWebSessionManager sLoginName sPassword to bResult
37312>>>        
37312>>>        If (bResult) Begin
37314>>>            Send Hide of oLogin
37315>>>            Send ShowHeader of ghoWebApp
37316>>>            WebSet psCSSClass of ghoWebApp to ""
37317>>>            
37317>>>            WebGet psPrevStateHash to sPrevStateHash
37318>>>            Send NavigateToStateHash of ghoWebApp sPrevStateHash True
37319>>>            
37319>>>            // clear the login values. we don't want to return the login id & password as synchronized properties....
37319>>>            WebSet psValue of oLoginName to ""
37320>>>            WebSet psValue of oPassword  to ""
37321>>>            WebSet pbVisible of oWarning to False
37322>>>        End
37322>>>>
37322>>>        Else Begin
37323>>>            WebSet pbVisible of oWarning to True
37324>>>        End
37324>>>>
37324>>>    End_Procedure
37325>>>    
37325>>>    Procedure OnSubmit
37328>>>        Send DoLogin
37329>>>    End_Procedure
37330>>>    
37330>>>    Procedure OnLoad
37333>>>        String sPrevStateHash sView
37333>>>        
37333>>>        Forward Send OnLoad
37335>>>        
37335>>>        //  Store the current state so we can go back to that later (only if it points to a different view)
37335>>>        Get StateHash of ghoWebApp to sPrevStateHash
37336>>>        Send ParseViewStateHash sPrevStateHash (&sView)
37337>>>        If (Lowercase(sView) <> Lowercase(psStateViewName(Self))) Begin
37339>>>            WebSet psPrevStateHash to sPrevStateHash
37340>>>        End
37340>>>>
37340>>>        
37340>>>    End_Procedure
