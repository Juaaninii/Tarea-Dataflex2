37572>>>    Procedure SetActionButtons
37575>>>        tWebNavigateData NavigateData
37575>>>        tWebNavigateData NavigateData
37575>>>        Boolean bHasRecord
37575>>>        Handle hoDD
37575>>>
37575>>>        Get Server to hoDD
37576>>>        Get GetNavigateData to NavigateData
37577>>>        Get HasRecord of hoDD to bHasRecord
37578>>>
37578>>>        // let's hide all buttons and then Show the ones we want
37578>>>        WebSet pbRender of oEditBtn to False
37579>>>        WebSet pbRender of oSaveBtn to False
37580>>>        WebSet pbRender of oCancelChangesBtn to False
37581>>>        WebSet pbRender of oDeleteBtn to False
37582>>>
37582>>>        If (NavigateData.bReadOnly) Begin
37584>>>            WebSet pbRender of oEditBtn to True
37585>>>        End
37585>>>>
37585>>>        Else Begin
37586>>>            WebSet pbRender of oSaveBtn to True
37587>>>            WebSet pbRender of oCancelChangesBtn to True
37588>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37589>>>        End
37589>>>>
37589>>>    End_Procedure
