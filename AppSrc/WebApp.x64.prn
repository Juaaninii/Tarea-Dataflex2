38658>>>    Procedure SetActionButtons
38661>>>        tWebNavigateData NavigateData
38661>>>        tWebNavigateData NavigateData
38661>>>        Boolean bHasRecord
38661>>>        Handle hoDD
38661>>>
38661>>>        Get Server to hoDD
38662>>>        Get GetNavigateData to NavigateData
38663>>>        Get HasRecord of hoDD to bHasRecord
38664>>>
38664>>>        // let's hide all buttons and then Show the ones we want
38664>>>        WebSet pbRender of oEditBtn to False
38665>>>        WebSet pbRender of oSaveBtn to False
38666>>>        WebSet pbRender of oCancelChangesBtn to False
38667>>>        WebSet pbRender of oDeleteBtn to False
38668>>>
38668>>>        If (NavigateData.bReadOnly) Begin
38670>>>            WebSet pbRender of oEditBtn to True
38671>>>        End
38671>>>>
38671>>>        Else Begin
38672>>>            WebSet pbRender of oSaveBtn to True
38673>>>            WebSet pbRender of oCancelChangesBtn to True
38674>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38675>>>        End
38675>>>>
38675>>>    End_Procedure
38676>>>
38676>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38679>>>        // Close after save
38679>>>        Send NavigateClose Self
38680>>>    End_Procedure
38681>>>
38681>>>    // this will close the view after a delete
38681>>>    Procedure OnViewDeleted Handle hoDDO
38684>>>        Send NavigateClose Self
38685>>>    End_Procedure
38686>>>
38686>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38689>>>        Case Begin
38689>>>            Case (NavigateData.eNavigateType = nfFromMain)
38691>>>                // If from main, this is a propbably a main file Select to Zoom.
38691>>>                Case Break
38692>>>
38692>>>            Case (NavigateData.eNavigateType = nfFromParent)
38695>>>                // If from parent, this is a constrained drill down.
38695>>>                Case Break
38696>>>
38696>>>            Case (NavigateData.eNavigateType = nfFromChild)
38699>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38699>>>                Case Break
38700>>>
38700>>>            Case Else // must be nfUndefined
38700>>>
38700>>>        Case End
38700>>>
38700>>>        Send SetActionButtons
38701>>>
38701>>>    End_Procedure
38702>>>
38702>>>End_Object 
