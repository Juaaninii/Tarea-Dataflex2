38691>>>    Procedure SetActionButtons
38694>>>        tWebNavigateData NavigateData
38694>>>        tWebNavigateData NavigateData
38694>>>        Boolean bHasRecord
38694>>>        Handle hoDD
38694>>>
38694>>>        Get Server to hoDD
38695>>>        Get GetNavigateData to NavigateData
38696>>>        Get HasRecord of hoDD to bHasRecord
38697>>>
38697>>>        // let's hide all buttons and then Show the ones we want
38697>>>        WebSet pbRender of oEditBtn to False
38698>>>        WebSet pbRender of oSaveBtn to False
38699>>>        WebSet pbRender of oCancelChangesBtn to False
38700>>>        WebSet pbRender of oDeleteBtn to False
38701>>>
38701>>>        If (NavigateData.bReadOnly) Begin
38703>>>            WebSet pbRender of oEditBtn to True
38704>>>        End
38704>>>>
38704>>>        Else Begin
38705>>>            WebSet pbRender of oSaveBtn to True
38706>>>            WebSet pbRender of oCancelChangesBtn to True
38707>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38708>>>        End
38708>>>>
38708>>>    End_Procedure
38709>>>
38709>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38712>>>        // Close after save
38712>>>        Send NavigateClose Self
38713>>>    End_Procedure
38714>>>
38714>>>    // this will close the view after a delete
38714>>>    Procedure OnViewDeleted Handle hoDDO
38717>>>        Send NavigateClose Self
38718>>>    End_Procedure
