38149>>>
38149>>>    Procedure SetActionButtons
38152>>>        tWebNavigateData NavigateData
38152>>>        tWebNavigateData NavigateData
38152>>>        Boolean bHasRecord
38152>>>        Handle hoDD
38152>>>
38152>>>        Get Server to hoDD
38153>>>        Get GetNavigateData to NavigateData
38154>>>        Get HasRecord of hoDD to bHasRecord
38155>>>
38155>>>        // let's hide all buttons and then Show the ones we want
38155>>>        WebSet pbRender of oEditBtn to False
38156>>>        WebSet pbRender of oSaveBtn to False
38157>>>        WebSet pbRender of oCancelChangesBtn to False
38158>>>        WebSet pbRender of oDeleteBtn to False
38159>>>
38159>>>        If (NavigateData.bReadOnly) Begin
38161>>>            WebSet pbRender of oEditBtn to True
38162>>>        End
38162>>>>
38162>>>        Else Begin
38163>>>            WebSet pbRender of oSaveBtn to True
38164>>>            WebSet pbRender of oCancelChangesBtn to True
38165>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38166>>>        End
38166>>>>
38166>>>    End_Procedure
38167>>>
38167>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38170>>>        // Close after save
38170>>>        Send NavigateClose Self
38171>>>    End_Procedure
38172>>>
38172>>>    // this will close the view after a delete
38172>>>    Procedure OnViewDeleted Handle hoDDO
38175>>>        Send NavigateClose Self
38176>>>    End_Procedure
38177>>>
38177>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38180>>>        Case Begin
38180>>>            Case (NavigateData.eNavigateType = nfFromMain)
38182>>>                // If from main, this is a propbably a main file Select to Zoom.
38182>>>                Case Break
38183>>>
38183>>>            Case (NavigateData.eNavigateType = nfFromParent)
38186>>>                // If from parent, this is a constrained drill down.
38186>>>                Case Break
38187>>>
38187>>>            Case (NavigateData.eNavigateType = nfFromChild)
38190>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38190>>>                Case Break
38191>>>
38191>>>            Case Else // must be nfUndefined
38191>>>
38191>>>        Case End
38191>>>
38191>>>        Send SetActionButtons
38192>>>
38192>>>    End_Procedure
38193>>>
38193>>>End_Object 
