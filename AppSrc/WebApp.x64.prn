38116>>>    Procedure SetActionButtons
38119>>>        tWebNavigateData NavigateData
38119>>>        tWebNavigateData NavigateData
38119>>>        Boolean bHasRecord
38119>>>        Handle hoDD
38119>>>
38119>>>        Get Server to hoDD
38120>>>        Get GetNavigateData to NavigateData
38121>>>        Get HasRecord of hoDD to bHasRecord
38122>>>
38122>>>        // let's hide all buttons and then Show the ones we want
38122>>>        WebSet pbRender of oEditBtn to False
38123>>>        WebSet pbRender of oSaveBtn to False
38124>>>        WebSet pbRender of oCancelChangesBtn to False
38125>>>        WebSet pbRender of oDeleteBtn to False
38126>>>
38126>>>        If (NavigateData.bReadOnly) Begin
38128>>>            WebSet pbRender of oEditBtn to True
38129>>>        End
38129>>>>
38129>>>        Else Begin
38130>>>            WebSet pbRender of oSaveBtn to True
38131>>>            WebSet pbRender of oCancelChangesBtn to True
38132>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38133>>>        End
38133>>>>
38133>>>    End_Procedure
38134>>>
38134>>>    Procedure OnViewSaved Handle hoServer Boolean bChanged
38137>>>        // Close after save
38137>>>        Send NavigateClose Self
38138>>>    End_Procedure
38139>>>
38139>>>    // this will close the view after a delete
38139>>>    Procedure OnViewDeleted Handle hoDDO
38142>>>        Send NavigateClose Self
38143>>>    End_Procedure
38144>>>
38144>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38147>>>        Case Begin
38147>>>            Case (NavigateData.eNavigateType = nfFromMain)
38149>>>                // If from main, this is a propbably a main file Select to Zoom.
38149>>>                Case Break
38150>>>
38150>>>            Case (NavigateData.eNavigateType = nfFromParent)
38153>>>                // If from parent, this is a constrained drill down.
38153>>>                Case Break
38154>>>
38154>>>            Case (NavigateData.eNavigateType = nfFromChild)
38157>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38157>>>                Case Break
38158>>>
38158>>>            Case Else // must be nfUndefined
38158>>>
38158>>>        Case End
38158>>>
38158>>>        Send SetActionButtons
38159>>>
38159>>>    End_Procedure
38160>>>
38160>>>End_Object 
