38719>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
38722>>>        Case Begin
38722>>>            Case (NavigateData.eNavigateType = nfFromMain)
38724>>>                // If from main, this is a propbably a main file Select to Zoom.
38724>>>                Case Break
38725>>>
38725>>>            Case (NavigateData.eNavigateType = nfFromParent)
38728>>>                // If from parent, this is a constrained drill down.
38728>>>                Case Break
38729>>>
38729>>>            Case (NavigateData.eNavigateType = nfFromChild)
38732>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38732>>>                Case Break
38733>>>
38733>>>            Case Else // must be nfUndefined
38733>>>
38733>>>        Case End
38733>>>
38733>>>        Send SetActionButtons
38734>>>
38734>>>    End_Procedure
38735>>>
38735>>>End_Object 
