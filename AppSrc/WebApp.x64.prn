37600>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37603>>>        Case Begin
37603>>>            Case (NavigateData.eNavigateType = nfFromMain)
37605>>>                // If from main, this is a propbably a main file Select to Zoom.
37605>>>                Case Break
37606>>>
37606>>>            Case (NavigateData.eNavigateType = nfFromParent)
37609>>>                // If from parent, this is a constrained drill down.
37609>>>                Case Break
37610>>>
37610>>>            Case (NavigateData.eNavigateType = nfFromChild)
37613>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37613>>>                Case Break
37614>>>
37614>>>            Case Else // must be nfUndefined
37614>>>
37614>>>        Case End
37614>>>
37614>>>        Send SetActionButtons
37615>>>
37615>>>    End_Procedure
37616>>>
37616>>>End_Object 
